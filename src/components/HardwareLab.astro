---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const hardware = [
  {
    name: 'Dell OptiPlex 7060',
    category: 'Proxmox Host',
    description: 'Intel i5-8500, 32GB RAM, 500GB NVMe SSD. Runs Proxmox VE as the home server backbone.',
    status: 'running' as const,
    icon: '🖥️',
    link: null,
  },
  {
    name: 'Home Assistant OS',
    category: 'Smart Home Hub',
    description: 'Running as a Proxmox VM with 4 vCPU and 4GB RAM. The brain of the entire smart home.',
    status: 'running' as const,
    icon: '🏠',
    link: 'https://www.home-assistant.io',
  },
  {
    name: 'Home Assistant Connect ZBT-2',
    category: 'Thread & Zigbee Radio',
    description: 'Dual-radio USB stick running as an OpenThread Border Router. Alongside the Google TV Streamer it forms a redundant Thread mesh — IKEA and other Thread sensors pair directly with HA without a third-party hub.',
    status: 'running' as const,
    icon: '📶',
    link: 'https://www.home-assistant.io/connectzbt2',
  },
  {
    name: 'UniFi Network',
    category: 'Networking',
    description: 'UniFi Ultra gateway, 8-port PoE switch, and two APs covering the house — rock-solid IoT VLAN isolation.',
    status: 'running' as const,
    icon: '🌐',
    link: 'https://ui.com',
  },
  {
    name: 'Reolink CX810',
    category: 'Security Camera',
    description: '4K PoE camera with AI detection for person, vehicle, and animal. Binary sensors feed HA automations for smart alerts.',
    status: 'active' as const,
    icon: '📷',
    link: 'https://reolink.com',
  },
  {
    name: 'Roborock S5 Max',
    category: 'Robot Vacuum',
    description: 'Interactive floor map with room-by-room cleaning control. Custom xiaomi-vacuum-map-card in Lovelace.',
    status: 'active' as const,
    icon: '🤖',
    link: 'https://www.roborock.com',
  },
  {
    name: 'Mammotion Luba Mini 2',
    category: 'Robotic Lawn Mower',
    description: 'GPS + RTK boundary mowing without perimeter wire. RTK corrections via iNav NetRTK. Native HA integration with weather-aware scheduling and satellite count monitoring.',
    status: 'active' as const,
    icon: '🌿',
    link: 'https://mammotion.com',
  },
  {
    name: 'Škoda Elroq',
    category: 'Electric Vehicle',
    description: 'Integrated via MyŠkoda: battery state, charge control, HVAC pre-conditioning, and price-aware smart charging automations.',
    status: 'active' as const,
    icon: '🚗',
    link: null,
  },
  {
    name: 'Tado Smart Heating',
    category: 'Climate',
    description: '5 zones with auto-discovery in HA. Presence-based setback and animated breathing cards on the dashboard.',
    status: 'running' as const,
    icon: '🌡️',
    link: 'https://www.tado.com',
  },
  {
    name: 'Sonos',
    category: 'Audio',
    description: 'Living room speaker unified with Google Nest Audio via HA scripts — controlled as one multi-room system.',
    status: 'active' as const,
    icon: '🔊',
    link: 'https://www.sonos.com',
  },
  {
    name: 'WiZ Smart Lighting',
    category: 'Lighting',
    description: 'Wi-Fi bulbs integrated natively. Used for circadian lighting schedules and TV movie-mode scene automation.',
    status: 'active' as const,
    icon: '💡',
    link: 'https://www.wizconnected.com',
  },
  {
    name: 'LEDVANCE SMART+',
    category: 'Lighting',
    description: 'Matter-compatible bulbs bridged to HA without a separate hub. Solid local control with no cloud dependency.',
    status: 'active' as const,
    icon: '🪔',
    link: 'https://www.ledvance.com',
  },
  {
    name: 'Govee',
    category: 'LED Lighting',
    description: 'Bias lighting and LED strips via the Govee Home integration. Scene-synced with media playback.',
    status: 'active' as const,
    icon: '✨',
    link: 'https://www.govee.com',
  },
  {
    name: 'IKEA Home Smart',
    category: 'Smart Devices',
    description: 'IKEA Thread sensors running on the shared Thread mesh. Two border routers (HA ZBT-2 and Google TV Streamer) provide redundant routing — devices pair directly into HA without a separate hub.',
    status: 'active' as const,
    icon: '🏗️',
    link: 'https://www.ikea.com',
  },
  {
    name: 'Bosch Home Connect',
    category: 'Appliances',
    description: 'Washer and dishwasher visible in HA via Home Connect. Push notification when cycles finish.',
    status: 'active' as const,
    icon: '🫧',
    link: 'https://www.home-connect.com',
  },
  {
    name: 'Mill Norway',
    category: 'Smart Heating',
    description: 'Wi-Fi panel radiators with native HA integration. Per-room temperature control without a gateway.',
    status: 'active' as const,
    icon: '♨️',
    link: 'https://www.millnorway.com',
  },
  {
    name: 'ESPHome Sensors',
    category: 'DIY Sensors',
    description: 'Custom ESP32/ESP8266 sensors for temperature, humidity, and more. Full local control, no cloud.',
    status: 'active' as const,
    icon: '📡',
    link: 'https://esphome.io',
  },
  {
    name: 'MailBoxGuard',
    category: 'LoRa IoT',
    description: 'PricelessToolkit sensor 200m away via LoRa. Instant push when mail arrives. Running 1+ year on a single battery.',
    status: 'active' as const,
    icon: '📬',
    link: 'https://github.com/PricelessToolkit/MailBoxGuard',
  },
];

const statusColors = {
  running: 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20',
  active: 'text-blue bg-blue-glow border-blue/20',
  testing: 'text-amber-400 bg-amber-400/10 border-amber-400/20',
};

const statusLabels = {
  running: t('hardware.status.running'),
  active: t('hardware.status.active'),
  testing: t('hardware.status.testing'),
};
---

<section id="hardware-lab" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="mb-12">
      <p class="font-mono text-blue text-sm mb-2 tracking-wider uppercase">// Hardware</p>
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-text-primary mb-4">{t('hardware.title')}</h2>
      <p class="text-text-muted max-w-2xl">{t('hardware.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {hardware.map(device => (
        <div class="glass-card p-6 group hover:border-blue/20 transition-all duration-300 hover:blue-glow">
          <div class="flex items-start justify-between mb-4">
            <span class="text-3xl">{device.icon}</span>
            <span class={`font-mono text-xs px-2.5 py-1 rounded-full border ${statusColors[device.status]}`}>
              {statusLabels[device.status]}
            </span>
          </div>
          <h3 class="font-heading font-bold text-text-primary mb-0.5 group-hover:text-blue transition-colors">
            {device.name}
          </h3>
          <p class="font-mono text-xs text-blue mb-3">{device.category}</p>
          <p class="text-text-muted text-sm leading-relaxed">{device.description}</p>
          {device.link && (
            <a
              href={device.link}
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="inline-flex items-center gap-1 mt-4 text-xs text-text-muted hover:text-blue transition-colors font-mono"
            >
              vendor site →
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
