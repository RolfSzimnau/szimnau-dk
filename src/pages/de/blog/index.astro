---
import Base from '../../../layouts/Base.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { useTranslations } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

const lang = 'de';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => p.data.lang === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<Base
  title="Blog — Heimautomatisierung & Home Assistant"
  description="Tiefe Einblicke, Hardware-Reviews und Automatisierungs-Blueprints für Home Assistant-Enthusiasten."
  lang={lang}
>
  <div class="max-w-6xl mx-auto px-6 py-24">
    <header class="mb-12">
      <p class="flex items-center gap-3 font-mono text-blue text-sm mb-3 tracking-wider uppercase"><span class="h-px w-8 bg-blue/60"></span>Blog</p>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-text-primary mb-4">{t('blog.page.title')}</h1>
      <p class="text-text-muted max-w-2xl">
        Praxisnahe Home Assistant-Guides, Hardware-Reviews und Automatisierungs-Blueprints. Kein Bullshit — nur was funktioniert.
      </p>
    </header>
    <section class="mb-12" aria-label="Artikel durchsuchen">
      <div id="search"></div>
    </section>
    {posts.length === 0 ? (
      <div class="glass-card p-12 text-center">
        <p class="text-text-muted font-mono">// Beiträge folgen bald...</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => {
          const slug = post.id.replace(`${lang}/`, '');
          return <BlogCard lang={lang} title={post.data.title} description={post.data.description} pubDate={post.data.pubDate} tags={post.data.tags} slug={slug} heroImage={post.data.heroImage} />;
        })}
      </div>
    )}
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-12">
        {allTags.map(tag => (
          <a href={`/de/blog/tag/${tag}/`} class="font-mono text-xs text-blue border border-blue/20 bg-blue-glow px-3 py-1 rounded-full hover:border-blue/60 transition-colors">#{tag}</a>
        ))}
      </div>
    )}
  </div>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        translations: { placeholder: 'Artikel durchsuchen…' }
      });
    });
  </script>
  <style is:global>
    #search {
      --pagefind-ui-scale: 0.9;
      --pagefind-ui-primary: #00d4ff;
      --pagefind-ui-text: #e2e8f0;
      --pagefind-ui-background: #0d1526;
      --pagefind-ui-border: rgba(255, 255, 255, 0.08);
      --pagefind-ui-tag: #111827;
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 14px;
      --pagefind-ui-image-border-radius: 10px;
      --pagefind-ui-font: 'Inter', system-ui, sans-serif;
    }
    #search .pagefind-ui__search-input::placeholder { color: #94a3b8; opacity: 1; }
    #search .pagefind-ui__result-link { color: #00d4ff; }
    #search .pagefind-ui__message,
    #search .pagefind-ui__result-excerpt { color: #94a3b8; }
    #search mark { background: rgba(0, 212, 255, 0.25); color: #e2e8f0; border-radius: 3px; }
  </style>
</Base>
