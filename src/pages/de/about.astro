---
import Base from '../../layouts/Base.astro';
import SponsorshipCTA from '../../components/SponsorshipCTA.astro';
import EmailLink from '../../components/EmailLink.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'de';
const t = useTranslations(lang);

const skills = [
  'Home Assistant', 'Proxmox VE', 'ESPHome', 'YAML Automatisierungen',
  'Lovelace Dashboards', 'LoRa / IoT', 'WiZ',
  'Microsoft Azure', 'PowerShell', 'ISO 27001', 'KI-Agenten',
  'Informationssicherheit', 'Netzwerkarchitektur',
];
---

<Base
  title="Über Rolf Szimnau"
  description="CISO und Senior IT-Leiter mit 29+ Jahren Erfahrung. Betreibt Home Assistant auf Proxmox und veröffentlicht praxisnahe Smart-Home-Guides auf Deutsch, Englisch und Dänisch."
  lang={lang}
>
  <div class="max-w-4xl mx-auto px-6 py-24">
    <header class="mb-16">
      <p class="font-mono text-blue text-sm mb-3 tracking-wider uppercase">// Über mich</p>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-text-primary mb-4">{t('about.title')}</h1>
      <p class="text-blue font-mono">{t('about.role')}</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <div class="md:col-span-2 space-y-5 text-text-muted leading-relaxed">
        <p>
          Ich bin <strong class="text-text-primary">Rolf Szimnau</strong> — CISO und Senior IT-Leiter bei
          Add-On Products, wo ich die volle Verantwortung für Cloud-Infrastruktur, Sicherheitsarchitektur
          und SaaS-Betrieb auf über 100 Servern trage. Tagsüber bedeutet das Azure, ISO 27001 und
          Enterprise-Kunden wie Maersk, Lego, Coloplast, Ørsted und die Bank of England. Abends
          bedeutet es Home Assistant, Proxmox und herauszufinden, warum der Rasenmäher jeden sonnigen
          Nachmittag um genau 16:30 Uhr stoppte.
        </p>
        <p>
          Zu Hause läuft <strong class="text-text-primary">Home Assistant OS als Proxmox-VM</strong>
          auf einem Dell OptiPlex 7060 — zusammen mit ESPHome-Sensoren, WiZ- und
          LEDVANCE-Beleuchtung, einem Mammotion Flora Mähroboter, Roborock S5 Max, Tado-Heizung in
          5 Zonen, einem per MyŠkoda integrierten Škoda Elroq für smartes Laden und einem LoRa-Briefkastensensor
          200 Meter die Einfahrt hinunter. Das UniFi-Netzwerk betreibt eine saubere IoT-VLAN-Isolation.
          Nichts läuft in einer Cloud, die ich nicht selbst kontrolliere.
        </p>
        <p>
          Neunundzwanzig Jahre Infrastrukturarbeit bedeuten, dass ich Heimautomatisierung genauso
          angehe wie Produktionssysteme: Zuverlässigkeit zuerst, keine Single Points of Failure,
          und jede Automation muss ihren Platz verdienen. Ich habe auch professionell KI-Agenten
          entwickelt — als Home Assistant LLM Vision in den Sicherheitskamera-Workflow brachte,
          wusste ich genau, was ich damit anfange.
        </p>
        <p>
          Diese Seite dokumentiert, was ich tatsächlich betreibe, was schiefläuft und was ich gelernt
          habe. Guides erscheinen auf <strong class="text-text-primary">Deutsch, Englisch und Dänisch</strong>
          — ich arbeite fließend in allen drei Sprachen. Wenn Sie als Hardware-Hersteller eine technisch
          versierte Zielgruppe erreichen möchten, ist der Sponsoring-Bereich unten für Sie.
        </p>
      </div>

      <div class="space-y-4">
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Fakten</h3>
          <ul class="space-y-2 text-sm text-text-muted">
            <li class="flex gap-2"><span class="text-blue">▹</span> Südliches Dänemark</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> CISO · Add-On Products</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> 29+ Jahre in der IT</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> DE · EN · DA</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Offen für Sponsoring</li>
          </ul>
        </div>
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Enterprise-Hintergrund</h3>
          <ul class="space-y-2 text-sm text-text-muted">
            <li class="flex gap-2"><span class="text-blue">▹</span> Maersk</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Lego</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Coloplast</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Ørsted</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Bank of England</li>
          </ul>
        </div>
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Kontakt</h3>
          <div class="space-y-2">
            <EmailLink class="block text-sm text-blue hover:underline font-mono" />
            <a href="https://www.linkedin.com/in/szimnau/" target="_blank" rel="noopener noreferrer" class="block text-sm text-blue hover:underline font-mono">LinkedIn →</a>
          </div>
        </div>
      </div>
    </div>

    <div class="mb-16">
      <h2 class="font-heading text-2xl font-bold text-text-primary mb-6">Technische Fähigkeiten</h2>
      <ul class="flex flex-wrap gap-2">
        {skills.map(skill => (
          <li class="font-mono text-sm text-text-muted border border-glass-border px-3 py-1.5 rounded-lg hover:border-blue/30 hover:text-blue transition-colors">{skill}</li>
        ))}
      </ul>
    </div>

    <SponsorshipCTA lang={lang} />
  </div>
</Base>
