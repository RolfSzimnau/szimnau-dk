---
import Base from '../../layouts/Base.astro';
import SponsorshipCTA from '../../components/SponsorshipCTA.astro';
import EmailLink from '../../components/EmailLink.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const skills = [
  'Home Assistant', 'Proxmox VE', 'ESPHome', 'YAML Automations',
  'Lovelace Dashboards', 'LoRa / IoT', 'WiZ',
  'Microsoft Azure', 'PowerShell', 'ISO 27001', 'AI Agents',
  'Information Security', 'Network Architecture',
];

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Rolf Szimnau',
  url: 'https://szimnau.dk',
  jobTitle: 'CISO & Technical Advisor',
  description: 'Rolf Szimnau is a CISO and Technical Advisor with 29+ years of experience. By day he runs enterprise cloud infrastructure for a SaaS company. At home he runs Home Assistant on Proxmox and publishes in-depth guides on automation, hardware, and smart home engineering.',
  sameAs: ['https://github.com/RolfSzimnau', 'https://www.linkedin.com/in/szimnau'],
  knowsAbout: ['Home Assistant', 'Home Automation', 'Proxmox', 'Smart Home', 'ESPHome', 'Microsoft Azure', 'Information Security'],
  knowsLanguage: ['English', 'Danish', 'German'],
};
---

<Base
  title="About Rolf Szimnau"
  description="CISO and Technical Advisor with 29+ years of experience. Runs Home Assistant on Proxmox and publishes real-world smart home guides in English, Danish and German."
  lang={lang}
>
  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />

  <div class="max-w-4xl mx-auto px-6 py-24">
    <header class="mb-16">
      <p class="font-mono text-blue text-sm mb-3 tracking-wider uppercase">// About</p>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-text-primary mb-4">{t('about.title')}</h1>
      <p class="text-blue font-mono">{t('about.role')}</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <div class="md:col-span-2 space-y-5 text-text-muted leading-relaxed">
        <p>
          I'm <strong class="text-text-primary">Rolf Szimnau</strong> — CISO and Technical Advisor at
          Add-On Products, where I carry full responsibility for cloud infrastructure, security posture,
          and SaaS operations across 100+ servers. During the day that means Azure, ISO 27001, and
          enterprise customers like Maersk, Lego, Coloplast, Ørsted, and Bank of England. In the evening
          it means Home Assistant, Proxmox, and figuring out why the lawn mower stopped at 16:30 every
          sunny afternoon.
        </p>
        <p>
          The home setup runs <strong class="text-text-primary">Home Assistant OS on a Proxmox VM</strong>
          hosted on a Dell OptiPlex 7060 — alongside ESPHome sensors, WiZ and LEDVANCE
          lighting, a Mammotion Luba Mini 2 — my little Flora, Roborock S5 Max, Tado heating across 5 zones,
          a Škoda Elroq integrated for smart charging, and a LoRa mailbox sensor 200 metres down the
          driveway. The network is UniFi throughout — an Ultra gateway, an 8-port switch with 4-port PoE, and two access points covering the house — with proper IoT VLAN isolation. Nothing runs in a cloud I don't control.
        </p>
        <p>
          Twenty-nine years of infrastructure work means I approach home automation the same way I approach
          production systems: reliability first, no single points of failure, and every automation has to
          earn its place. I've also built AI agents professionally — so when Home Assistant added LLM Vision
          to the security camera workflow, I knew exactly what I was doing with it.
        </p>
        <p>
          This site documents what I actually run, what breaks, and what I've learned. Guides are published
          in <strong class="text-text-primary">English, Danish, and German</strong> — I work fluently in all three.
          If you're a hardware vendor looking for a technically credible audience, the sponsorship section below
          is for you.
        </p>
      </div>

      <div class="space-y-4">
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Quick Facts</h3>
          <ul class="space-y-2 text-sm text-text-muted">
            <li class="flex gap-2"><span class="text-blue">▹</span> Southern Denmark</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> CISO · Add-On Products</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> 29+ years in IT</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> EN · DA · DE</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Open to sponsorships</li>
          </ul>
        </div>
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Enterprise background</h3>
          <ul class="space-y-2 text-sm text-text-muted">
            <li class="flex gap-2"><span class="text-blue">▹</span> Maersk</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Lego</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Coloplast</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Ørsted</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Bank of England</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Governmental</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Education</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Telecommunication</li>
          </ul>
        </div>
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Contact</h3>
          <div class="space-y-2">
            <EmailLink class="block text-sm text-blue hover:underline font-mono" />
            <a href="https://www.linkedin.com/in/szimnau/" target="_blank" rel="noopener noreferrer" class="block text-sm text-blue hover:underline font-mono">LinkedIn →</a>
          </div>
        </div>
      </div>
    </div>

    <div class="mb-16">
      <h2 class="font-heading text-2xl font-bold text-text-primary mb-6">Technical Skills</h2>
      <ul class="flex flex-wrap gap-2">
        {skills.map(skill => (
          <li class="font-mono text-sm text-text-muted border border-glass-border px-3 py-1.5 rounded-lg hover:border-blue/30 hover:text-blue transition-colors">
            {skill}
          </li>
        ))}
      </ul>
    </div>

    <SponsorshipCTA lang={lang} />
  </div>
</Base>
