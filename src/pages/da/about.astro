---
import Base from '../../layouts/Base.astro';
import SponsorshipCTA from '../../components/SponsorshipCTA.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'da';
const t = useTranslations(lang);

const skills = [
  'Home Assistant', 'Proxmox VE', 'ESPHome', 'Node-RED',
  'YAML Automationer', 'Lovelace Dashboards', 'Wi-Fi IoT', 'Shelly',
  'WiZ', 'Microsoft Azure', 'PowerShell', 'Docker',
];
---

<Base
  title="Om Rolf Szimnau"
  description="Hjemmeautomatiserings-specialist og IT-rådgiver med 29+ års erfaring. Kører Home Assistant på Proxmox og deler virkelighedsbaseret smart home-viden."
  lang={lang}
>
  <div class="max-w-4xl mx-auto px-6 py-24">
    <header class="mb-16">
      <p class="font-mono text-blue text-sm mb-3 tracking-wider uppercase">// Om mig</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-text-primary mb-4">{t('about.title')}</h1>
      <p class="text-blue font-mono">{t('about.role')}</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <div class="md:col-span-2 space-y-5 text-text-muted leading-relaxed">
        <p>
          Jeg er <strong class="text-text-primary">Rolf Szimnau</strong> — Senior IT-rådgiver med 29+ års
          erfaring inden for teknologi og en stigende passion for hjemmeautomatisering. Det startede med
          nysgerrighed på smarte pærer og er nu udviklet til et fuldt Proxmox home lab med Home Assistant i centrum.
        </p>
        <p>
          Jeg kører <strong class="text-text-primary">Home Assistant OS som en Proxmox VM</strong> på en Dell
          OptiPlex 7060, sammen med custom ESPHome-sensorer, Shelly-kontakter, WiZ-belysning og et UniFi-netværk
          med ordentlig IoT VLAN-isolering. Dette site er, hvor jeg dokumenterer, hvad jeg bygger, hvad der går galt,
          og hvad jeg lærer.
        </p>
        <p>
          Min professionelle baggrund inden for Microsoft Azure, infrastruktur og SaaS-drift betyder, at jeg
          tilgår hjemmeautomatisering med en ingeniørs tankegang — jeg prioriterer pålidelighed og sikkerhed.
        </p>
      </div>
      <div class="space-y-6">
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Fakta</h3>
          <ul class="space-y-2 text-sm text-text-muted">
            <li class="flex gap-2"><span class="text-blue">▹</span> Baseret i Danmark</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> 29+ år i IT</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> EN · DA · DE</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Home lab entusiast</li>
          </ul>
        </div>
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Kontakt</h3>
          <a href="mailto:rolf@szimnau.dk" class="text-sm text-blue hover:underline">rolf@szimnau.dk</a>
        </div>
      </div>
    </div>

    <div class="mb-16">
      <h2 class="text-2xl font-bold text-text-primary mb-6">Tekniske kompetencer</h2>
      <ul class="flex flex-wrap gap-2">
        {skills.map(skill => (
          <li class="font-mono text-sm text-text-muted border border-glass-border px-3 py-1.5 rounded-lg hover:border-blue/30 hover:text-blue transition-colors">{skill}</li>
        ))}
      </ul>
    </div>

    <SponsorshipCTA lang={lang} />
  </div>
</Base>
