---
import Base from '../../layouts/Base.astro';
import EmailLink from '../../components/EmailLink.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'da';
const t = useTranslations(lang);

const skills = [
  'Home Assistant', 'Proxmox VE', 'ESPHome', 'YAML Automationer',
  'Lovelace Dashboards', 'LoRa / IoT', 'WiZ',
  'Microsoft Azure', 'PowerShell', 'ISO 27001', 'AI Agenter',
  'Informationssikkerhed', 'Netværksarkitektur',
];
---

<Base
  title="Om Rolf Szimnau"
  description="CISO og Technical Advisor med 29+ års erfaring. Kører Home Assistant på Proxmox og deler virkelighedsbaserede smart home-guides på dansk, engelsk og tysk."
  lang={lang}
>
  <div class="max-w-4xl mx-auto px-6 py-24">
    <header class="mb-16">
      <p class="flex items-center gap-3 font-mono text-blue text-sm mb-3 tracking-wider uppercase"><span class="h-px w-8 bg-blue/60"></span>Om mig</p>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-text-primary mb-4">{t('about.title')}</h1>
      <p class="text-blue font-mono">{t('about.role')}</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <div class="md:col-span-2 space-y-5 text-text-muted leading-relaxed">
        <p>
          Jeg er <strong class="text-text-primary">Rolf Szimnau</strong> — CISO og Technical Advisor hos
          Add-On Products, hvor jeg har det fulde ansvar for cloud-infrastruktur, sikkerhed og
          SaaS-drift på tværs af 100+ servere. I arbejdstiden betyder det Azure, ISO 27001 og
          enterprise-kunder som Maersk, Lego, Coloplast, Ørsted og Bank of England. Om aftenen
          betyder det Home Assistant, Proxmox og at finde ud af, hvorfor plæneklipperen stoppede
          præcis 16:30 hver solrig eftermiddag.
        </p>
        <p>
          Hjemme kører <strong class="text-text-primary">Home Assistant OS som en Proxmox VM</strong>
          på en Dell OptiPlex 7060 — sammen med ESPHome-sensorer, WiZ og LEDVANCE
          belysning, en Mammotion Luba Mini 2 — min lille Flora, Roborock S5 Max, Tado-opvarmning i 5 zoner,
          en Škoda Elroq integreret til smart opladning og en LoRa-postkassesensor 200 meter nede
          ad indkørslen. Netværket er UniFi i hele huset — en Ultra gateway, en 8-port switch med 4-port PoE og to access points — med ordentlig IoT VLAN-isolering. Intet kører i en
          cloud, jeg ikke selv styrer.
        </p>
        <p>
          Ni-og-tyve år med infrastruktur betyder, at jeg tilgår hjemmeautomatisering på samme måde
          som produktionssystemer: pålidelighed først, ingen single points of failure, og enhver
          automation skal fortjene sin plads. Jeg har også bygget AI-agenter professionelt —
          så da Home Assistant fik LLM Vision ind i sikkerhedskamera-workflowet, vidste jeg
          præcis, hvad jeg lavede med det.
        </p>
        <p>
          Dette site dokumenterer, hvad jeg rent faktisk kører, hvad der går galt, og hvad jeg har
          lært. Guides udgives på <strong class="text-text-primary">dansk, engelsk og tysk</strong>
          — jeg arbejder flydende på alle tre. Er du en hardware-leverandør, der ønsker at nå et
          teknisk kompetent publikum, er sponsoratsektionen nedenfor til dig.
        </p>
      </div>

      <div class="space-y-4">
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Fakta</h3>
          <ul class="space-y-2 text-sm text-text-muted">
            <li class="flex gap-2"><span class="text-blue">▹</span> Sydsjælland, Danmark</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> CISO · Add-On Products</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> 29+ år i IT</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> DA · EN · DE</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Åben for sponsorater</li>
          </ul>
        </div>
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Enterprise-baggrund</h3>
          <ul class="space-y-2 text-sm text-text-muted">
            <li class="flex gap-2"><span class="text-blue">▹</span> Maersk</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Lego</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Coloplast</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Ørsted</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Bank of England</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Shell</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Airbus</li>
            <li class="flex gap-2"><span class="text-blue">▹</span> Barclays</li>
          </ul>
        </div>
        <div class="glass-card p-5">
          <h3 class="font-mono text-blue text-xs uppercase tracking-wider mb-3">Kontakt</h3>
          <div class="space-y-2">
            <EmailLink class="block text-sm text-blue hover:underline font-mono" />
            <a href="https://www.linkedin.com/in/szimnau/" target="_blank" rel="noopener noreferrer" class="block text-sm text-blue hover:underline font-mono">LinkedIn →</a>
          </div>
        </div>
      </div>
    </div>

    <div class="mb-16">
      <h2 class="font-heading text-2xl font-bold text-text-primary mb-6">Tekniske kompetencer</h2>
      <ul class="flex flex-wrap gap-2">
        {skills.map(skill => (
          <li class="font-mono text-sm text-text-muted border border-glass-border px-3 py-1.5 rounded-lg hover:border-blue/30 hover:text-blue transition-colors">{skill}</li>
        ))}
      </ul>
    </div>

  </div>
</Base>
