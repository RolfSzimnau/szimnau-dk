---
import Base from './Base.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags: string[];
  translationKey: string;
  faqs?: Array<{ question: string; answer: string }>;
}

const { title, description, lang, pubDate, updatedDate, heroImage, tags, faqs } = Astro.props;

const formattedDate = pubDate.toLocaleDateString(
  lang === 'da' ? 'da-DK' : lang === 'de' ? 'de-DE' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Rolf Szimnau',
    url: 'https://szimnau.dk',
  },
  publisher: {
    '@type': 'Person',
    name: 'Rolf Szimnau',
    url: 'https://szimnau.dk',
  },
  image: heroImage ?? 'https://szimnau.dk/og-default.png',
  url: Astro.url.href,
  keywords: tags.join(', '),
  inLanguage: lang,
};
---

<Base title={title} description={description} lang={lang} type="article" pubDate={pubDate} heroImage={heroImage}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqs && faqs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map(f => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer }
      }))
    })} />
  )}
  <article class="max-w-3xl mx-auto px-6 py-24">
    <header class="mb-12">
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold text-text-primary leading-tight mb-6">
        {title}
      </h1>
      <p class="text-text-muted text-lg mb-6">{description}</p>
      <div class="flex flex-wrap gap-2 mb-6">
        {tags.map(tag => (
          <span class="font-mono text-xs text-blue border border-blue/30 px-3 py-1 rounded-full bg-blue-glow">
            #{tag}
          </span>
        ))}
      </div>
      <div class="flex items-center gap-4 text-sm text-text-muted font-mono border-t border-glass-border pt-6">
        <span>{formattedDate}</span>
        {updatedDate && <span class="text-blue">Updated {updatedDate.toLocaleDateString()}</span>}
      </div>
    </header>

    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        width="768"
        height="432"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="w-full rounded-2xl mb-12 border border-glass-border"
      />
    )}

    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
